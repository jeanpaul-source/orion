# Copy to .env and fill in real values.
# .env is gitignored — never commit it.

# vLLM (chat — OpenAI-compatible API)
VLLM_URL=http://localhost:8000
CHAT_MODEL=Qwen/Qwen2.5-32B-Instruct-AWQ

# Ollama (embeddings only — nomic-embed-text runs on CPU)
OLLAMA_HOST=http://192.168.5.10:11434
EMBED_MODEL=nomic-embed-text:latest

# Set to true to automatically create an SSH tunnel to Ollama or vLLM
# (needed if ports are firewalled — HAL tries auto-tunnel by default)
USE_SSH_TUNNEL=false

# pgvector
PGVECTOR_DSN=postgresql://kb_user:CHANGEME@192.168.5.10:5432/knowledge_base

# Prometheus — port 9091, NOT 9090 (9090 is Cockpit, a different service entirely)
PROMETHEUS_URL=http://192.168.5.10:9091

# ntopng traffic monitor REST API
NTOPNG_URL=http://localhost:3000

# Lab SSH
LAB_HOST=192.168.5.10
LAB_USER=jp

# ntfy push alerts — leave empty to disable
NTFY_URL=

# Metrics instance label — used to partition Pushgateway metrics per host.
# Defaults to hostname if not set. Set explicitly so Grafana labels are predictable.
# laptop value: laptop  |  server value: the-lab
HAL_INSTANCE=

# Prometheus Pushgateway — leave empty to disable metrics push
# Server: http://localhost:9092  |  Laptop: http://192.168.5.10:9092
PROM_PUSHGATEWAY=

# Logging
HAL_LOG_JSON=1
HAL_LOG_LEVEL=INFO

# OpenTelemetry traces — leave at default or point at a Tempo/Jaeger OTLP HTTP endpoint
OTLP_ENDPOINT=http://localhost:4318
# Set to true to disable tracing entirely (no probe, no exporter, no background thread).
# Useful on machines where no Tempo/Jaeger receiver is deployed and the 1s TCP probe
# at startup is undesirable.
# OTEL_SDK_DISABLED=true

# Telegram bot — get token from @BotFather, user ID from @userinfobot
TELEGRAM_BOT_TOKEN=
TELEGRAM_ALLOWED_USER_ID=

# Tavily web search — get key from https://tavily.com — empty disables web_search
TAVILY_API_KEY=
