# Copy to .env and fill in real values.
# .env is gitignored — never commit it.

# Ollama
OLLAMA_HOST=http://192.168.5.10:11434
OLLAMA_MODEL=qwen2.5-coder-14b-32k:latest
EMBED_MODEL=nomic-embed-text:latest

# Set to true to automatically create an SSH tunnel to Ollama
# (needed if port 11434 is firewalled — HAL tries auto-tunnel by default)
USE_SSH_TUNNEL=false

# pgvector
PGVECTOR_DSN=postgresql://kb_user:CHANGEME@192.168.5.10:5432/knowledge_base

# Prometheus
PROMETHEUS_URL=http://192.168.5.10:9091

# Lab SSH
LAB_HOST=192.168.5.10
LAB_USER=jp
