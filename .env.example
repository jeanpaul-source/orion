# Copy to .env and fill in real values.
# .env is gitignored — never commit it.

# vLLM (chat — OpenAI-compatible API)
VLLM_URL=http://localhost:8000
CHAT_MODEL=Qwen/Qwen2.5-32B-Instruct-AWQ

# Ollama (embeddings only — nomic-embed-text runs on CPU)
OLLAMA_HOST=http://192.168.5.10:11434
EMBED_MODEL=nomic-embed-text:latest

# Set to true to automatically create an SSH tunnel to Ollama or vLLM
# (needed if ports are firewalled — HAL tries auto-tunnel by default)
USE_SSH_TUNNEL=false

# pgvector
PGVECTOR_DSN=postgresql://kb_user:CHANGEME@192.168.5.10:5432/knowledge_base

# Prometheus — port 9091, NOT 9090 (9090 is Cockpit, a different service entirely)
PROMETHEUS_URL=http://192.168.5.10:9091

# ntopng traffic monitor REST API
NTOPNG_URL=http://localhost:3000

# Lab SSH
# LAB_HOST: SSH target for tool execution (run_command, list_dir, read_file, write_file).
# Running HAL ON the lab server → use localhost (executor skips SSH, runs directly).
# Running HAL from a laptop   → use the server IP and set USE_SSH_TUNNEL=true.
LAB_HOST=192.168.5.10
LAB_USER=jp

# ntfy push alerts — leave empty to disable
NTFY_URL=

# Metrics instance label — used to partition Pushgateway metrics per host.
# Defaults to hostname if not set. Set explicitly so Grafana labels are predictable.
# laptop value: laptop  |  server value: the-lab
HAL_INSTANCE=

# Prometheus Pushgateway — leave empty to disable metrics push
# Server: http://localhost:9092  |  Laptop: http://192.168.5.10:9092
PROM_PUSHGATEWAY=

# Logging
HAL_LOG_JSON=1
HAL_LOG_LEVEL=INFO

# OpenTelemetry traces — leave at default or point at a Tempo/Jaeger OTLP HTTP endpoint
OTLP_ENDPOINT=http://localhost:4318
# Set to true to disable tracing entirely (no probe, no exporter, no background thread).
# Useful on machines where no Tempo/Jaeger receiver is deployed and the 1s TCP probe
# at startup is undesirable.
# OTEL_SDK_DISABLED=true

# Telegram bot — get token from @BotFather, user ID from @userinfobot
TELEGRAM_BOT_TOKEN=
TELEGRAM_ALLOWED_USER_ID=

# Tavily web search — get key from https://tavily.com — empty disables web_search
TAVILY_API_KEY=

# Web UI authentication — bearer token required for /chat over the network.
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
# Leave empty ONLY if port is bound to 127.0.0.1 (localhost).
HAL_WEB_TOKEN=

# Harvest topology — only needed if your lab differs from defaults
# Base directory that contains compose stacks (monitoring-stack/, pgvector-kb/, etc.)
# INFRA_BASE=/opt/homelab-infrastructure
# Root directory of pre-scraped reference documents
# STATIC_DOCS_ROOT=/data/orion/orion-data/documents/raw
# Space-separated systemd unit names to read and ingest
# HARVEST_SYSTEMD_UNITS=ollama.service pgvector-kb-api.service

# System prompt identity
# Human-readable hostname shown in the prompt (e.g. "the-lab"); empty = use LAB_HOST IP only
# LAB_HOSTNAME=the-lab
# One-line hardware summary shown in the prompt; empty = omit the hardware line
# LAB_HARDWARE_SUMMARY=Intel Core Ultra 7 265K (20 cores) · 62 GB DDR5 · RTX 3090 Ti (24 GB VRAM)

# Judge extensions — additive only; base security rules cannot be weakened
# Colon-separated absolute path prefixes that the Judge treats as sensitive
# (read → tier 1, write → tier 3, command touching them → tier 1)
# JUDGE_EXTRA_SENSITIVE_PATHS=/run/homelab-secrets:/mnt/nas/private

# Watchdog proactive trend thresholds — rate-of-change (pct points per hour) that
# triggers an early alert before the current-value threshold is breached.
# CPU and load are excluded — too spiky for rate-of-change alerting.
# WATCHDOG_DISK_RATE_PCT_PER_HOUR=5.0
# WATCHDOG_MEM_RATE_PCT_PER_HOUR=5.0
# WATCHDOG_SWAP_RATE_PCT_PER_HOUR=10.0
# WATCHDOG_GPU_VRAM_RATE_PCT_PER_HOUR=5.0

# LLM sampling — Qwen-recommended + min_p to prevent Chinese language mixing.
# These values match Qwen2.5's generation_config.json; min_p is the community fix
# for the known CJK token leakage issue (https://github.com/QwenLM/Qwen3/issues/302).
# LLM_TEMPERATURE=0.7
# LLM_TOP_P=0.8
# LLM_MIN_P=0.05
# LLM_REPETITION_PENALTY=1.05
