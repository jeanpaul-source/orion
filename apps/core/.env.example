# ORION Core - Environment Configuration
#
# Copy this file to .env and configure for your environment.
# DO NOT commit .env to git!

# ============================================================================
# APPLICATION
# ============================================================================
ORION_ENVIRONMENT=production  # production, development, test
ORION_LOG_LEVEL=INFO          # DEBUG, INFO, WARNING, ERROR, CRITICAL

# ============================================================================
# API KEYS
# ============================================================================
# AnythingLLM API Key (from Settings → API Keys in AnythingLLM UI)
ORION_ANYTHINGLLM_API_KEY=your-api-key-here
# Required authentication keys for vLLM and Qdrant services
# These must match the credentials configured in the ORION stack on the lab host
VLLM_API_KEY=your-vllm-api-key
QDRANT_API_KEY=your-qdrant-api-key

# ============================================================================
# SERVICE URLS
# ============================================================================
# These use Docker service names when running in Docker Compose.
# Override only if you have a different setup.

# LLM Inference
ORION_VLLM_URL=http://vllm:8000
ORION_OLLAMA_URL=http://host.docker.internal:11434

# RAG Stack
ORION_QDRANT_URL=http://qdrant:6333
ORION_ANYTHINGLLM_URL=http://anythingllm:3001

# Workflow automation
ORION_N8N_URL=http://n8n:5678

# ============================================================================
# LLM CONFIGURATION
# ============================================================================
ORION_VLLM_MODEL=Qwen/Qwen2.5-14B-Instruct-AWQ
ORION_OLLAMA_MODEL=qwen2.5:32b
ORION_DEFAULT_TEMPERATURE=0.7
ORION_DEFAULT_MAX_TOKENS=2048

# ============================================================================
# RAG CONFIGURATION
# ============================================================================
ORION_QDRANT_COLLECTION=orion_homelab
ORION_RAG_TOP_K=5

# ============================================================================
# FEATURES
# ============================================================================
ORION_ENABLE_KNOWLEDGE=true   # RAG knowledge base queries
ORION_ENABLE_ACTION=true      # Tool execution and tasks
ORION_ENABLE_LEARNING=true    # Self-teaching capabilities
ORION_ENABLE_WATCH=true       # System monitoring

# ============================================================================
# TRACING
# ============================================================================
ORION_ENABLE_TRACING=true
ORION_TRACING_ENDPOINT=http://localhost:4318/v1/traces

# ============================================================================
# PERFORMANCE
# ============================================================================
ORION_ENABLE_CACHE=true
ORION_CACHE_TTL=3600  # seconds
ORION_MAX_CONCURRENT_REQUESTS=10
ORION_REQUEST_TIMEOUT=60  # seconds

# ============================================================================
# SECURITY
# ============================================================================
ORION_CORS_ORIGINS=*  # Use * or JSON/comma list, e.g. ["http://localhost:3000"]
ORION_REQUIRE_AUTH=false  # Future feature

# ============================================================================
# TELEGRAM BOT (Phase 4)
# ============================================================================
# Enable Telegram bot for mobile access and push notifications
ORION_TELEGRAM_ENABLED=false

# Bot token from @BotFather (https://t.me/BotFather)
# Example: 123456789:ABCdefGHIjklMNOpqrsTUVwxyz
ORION_TELEGRAM_BOT_TOKEN=

# Allowed Telegram user IDs (security whitelist)
# Get your ID from @userinfobot (https://t.me/userinfobot)
# Format: Python list [user_id1,user_id2] - NO SPACES!
# Example: [123456789,987654321]
ORION_TELEGRAM_ALLOWED_USERS=[]

# Enable push notifications for alerts
ORION_TELEGRAM_NOTIFICATION_ENABLED=true
