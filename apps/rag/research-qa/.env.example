# ORION Research-QA Environment Variables
# Copy this to .env and fill in your values

# =============================================================================
# AnythingLLM Configuration
# =============================================================================

# AnythingLLM API URL
# Default: http://192.168.5.10:3001 (host machine)
# For local development: http://localhost:3001
ANYTHINGLLM_URL=http://192.168.5.10:3001

# AnythingLLM API Key (REQUIRED)
# Get from: AnythingLLM Settings → Developer API Keys
# Generate with: openssl rand -hex 32
ANYTHINGLLM_API_KEY=

# =============================================================================
# Vector Database Configuration
# =============================================================================

# Qdrant vector database URL
# Default: http://localhost:6333
# For host deployment: http://192.168.5.10:6333
QDRANT_URL=http://localhost:6333

# Qdrant API Key (if authentication enabled)
# Should match the key in infrastructure/.env
# QDRANT_API_KEY=

# =============================================================================
# Data Paths
# =============================================================================

# Root directory containing documents to process
# This directory should contain subdirectories: github/, academic/, manuals/, etc.
ORION_DOCUMENT_ROOT=/mnt/nvme1/orion-data/documents/raw

# Ingestion registry database path
# Tracks processed documents to prevent re-processing
ORION_INGESTION_DB=/mnt/nvme1/orion-data/documents/metadata/ingestion.db

# =============================================================================
# Processing Configuration
# =============================================================================

# Maximum files to process per run (0 = unlimited)
# ORION_MAX_FILES=0

# Batch size for document processing
# ORION_BATCH_SIZE=10

# Document processing timeout (seconds)
# ORION_PROCESSING_TIMEOUT=300

# =============================================================================
# Quality Gates
# =============================================================================

# Minimum text density (text chars / total chars)
# Documents below this threshold are rejected
# ORION_MIN_TEXT_DENSITY=0.3

# Minimum token count
# Documents below this count are rejected
# ORION_MIN_TOKENS=200

# Maximum token count
# Documents above this count are split
# ORION_MAX_TOKENS=8000

# =============================================================================
# Domain-Specific Configuration
# =============================================================================

# GitHub documentation quality threshold
# ORION_GITHUB_MIN_DENSITY=0.3
# ORION_GITHUB_MIN_TOKENS=200

# Academic papers quality threshold
# ORION_ACADEMIC_MIN_DENSITY=0.4
# ORION_ACADEMIC_MIN_TOKENS=500

# Technical manuals quality threshold
# ORION_MANUALS_MIN_DENSITY=0.15
# ORION_MANUALS_MIN_TOKENS=100

# =============================================================================
# Logging Configuration
# =============================================================================

# Log level: DEBUG, INFO, WARNING, ERROR, CRITICAL
# ORION_LOG_LEVEL=INFO

# Log file path (default: logs to stdout)
# ORION_LOG_FILE=/var/log/orion-research-qa.log

# =============================================================================
# Performance Tuning
# =============================================================================

# Number of worker processes
# ORION_NUM_WORKERS=4

# Enable progress bar
# ORION_SHOW_PROGRESS=true

# Dry run mode (process but don't upload to AnythingLLM)
# ORION_DRY_RUN=false
