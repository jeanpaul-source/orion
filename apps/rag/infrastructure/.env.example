# ORION Environment Variables Template
# Copy this to .env.production and fill in your actual values

# =============================================================================
# HuggingFace Token
# =============================================================================
# Required only for gated models (Llama, etc.)
# Leave empty for open models like Qwen
# Get from: https://huggingface.co/settings/tokens
HF_TOKEN=

# =============================================================================
# API Keys (SECURITY: Generate strong keys!)
# =============================================================================
# Generate with: openssl rand -hex 32

# vLLM API Key (protects LLM inference API)
# Required: vLLM will not start without this
VLLM_API_KEY=

# Qdrant API Key (protects vector database)
# Required: Qdrant will not start without this
QDRANT_API_KEY=

# =============================================================================
# n8n Workflow Automation
# =============================================================================
# n8n admin credentials
# CRITICAL: Change these from defaults!
# Generate password with: openssl rand -base64 32
N8N_ADMIN_USER=admin
N8N_ADMIN_PASSWORD=

# n8n owner email (for user management)
N8N_OWNER_EMAIL=admin@localhost

# n8n webhook URL (optional, for webhook triggers)
N8N_WEBHOOK_URL=

# =============================================================================
# AnythingLLM Authentication (Optional)
# =============================================================================
# This is the password to access AnythingLLM's web interface
# Generate with: openssl rand -hex 32
# Leave commented for no-auth homelab mode
#ANYTHINGLLM_AUTH_TOKEN=
