# ORION Harvester Environment Variables
# Copy this to .env and fill in your values

# =============================================================================
# Academic API Keys (Optional but Recommended)
# =============================================================================
# These increase rate limits and access to premium features

# Semantic Scholar API Key
# Free tier: 100 req/5min, Registered: 1000 req/5min
# Get from: https://www.semanticscholar.org/product/api#api-key-form
ORION_S2_API_KEY=

# CORE API Key
# Free tier: 100 req/day, Registered: 1000 req/day
# Get from: https://core.ac.uk/services/api
ORION_CORE_API_KEY=

# GitHub Personal Access Token
# Increases rate limit from 60 → 5,000 req/hr
# Get from: https://github.com/settings/tokens (public_repo scope)
ORION_GITHUB_TOKEN=

# Stack Overflow API Key
# Increases quota from 300 → 10,000 req/day
# Get from: https://stackapps.com/apps/oauth/register
ORION_SO_API_KEY=

# =============================================================================
# Contact Information (Polite API Headers)
# =============================================================================
# Many APIs request contact info for abuse prevention
# This is optional but recommended for academic APIs
ORION_CONTACT_EMAIL=your-email@example.com

# =============================================================================
# Quality Thresholds
# =============================================================================
# Minimum quality criteria for harvested content

# Minimum GitHub stars for repository documentation
ORION_MIN_GITHUB_STARS=100

# Minimum Stack Overflow score for answers
ORION_MIN_SO_SCORE=10

# Maximum results per search term (prevents over-collection)
ORION_MAX_RESULTS_PER_TERM=5

# =============================================================================
# Feature Flags
# =============================================================================

# Enable NLP semantic filtering (requires sentence-transformers)
# Default: false (disabled for performance)
ORION_USE_EMBEDDINGS=false

# =============================================================================
# Service URLs (Default: localhost)
# =============================================================================

# Qdrant vector database URL
ORION_QDRANT_URL=http://localhost:6333

# vLLM inference server URL
ORION_VLLM_URL=http://localhost:8000

# =============================================================================
# Data Paths
# =============================================================================

# Output directory for harvested documents
# Default: Uses relative path data/library/
# For production: Use absolute path
# ORION_OUTPUT_DIR=/mnt/nvme1/orion-data/documents/raw

# Harvest registry database path
# Default: Uses relative path data/harvest-registry.db
# For production: Use absolute path
# ORION_REGISTRY_DB=/mnt/nvme1/orion-data/documents/metadata/harvest-registry.db

# Base data directory (overrides individual paths)
# If set, all data/ paths are relative to this
# ORION_DATA_DIR=/path/to/harvester/data

# =============================================================================
# Advanced Configuration
# =============================================================================

# HTTP request timeout (seconds)
# ORION_HTTP_TIMEOUT=30

# Maximum concurrent downloads
# ORION_MAX_WORKERS=5

# Retry attempts for failed requests
# ORION_MAX_RETRIES=3

# =============================================================================
# Logging Configuration
# =============================================================================

# Log level: DEBUG, INFO, WARNING, ERROR, CRITICAL
# ORION_LOG_LEVEL=INFO

# Log file path (default: logs to stdout)
# ORION_LOG_FILE=/var/log/orion-harvester.log
