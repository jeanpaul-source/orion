# ORION profile: laptop orchestrator, host-only compute
# Keep all compute on the host; the laptop only orchestrates.

export ORION_QDRANT_URL="http://192.168.5.10:6333"
export ORION_QDRANT_COLLECTION="orion_homelab"

# Use host embedding HTTP API to avoid local compute
export ORION_EMBED_URL="http://192.168.5.10:8001"

# vLLM (OpenAI-compatible) endpoint and default model on host
export ORION_VLLM_URL="http://192.168.5.10:8000/v1"
export ORION_VLLM_MODEL="Qwen/Qwen2.5-Coder-7B-Instruct"

# Ensure local CUDA is never attempted on laptop
export ORION_FORCE_CPU=1

# Optional overrides
# export ORION_DATA_DIR=""
# export ORION_CONFIG_DIR=""
# export ORION_LOG_LEVEL="INFO"
