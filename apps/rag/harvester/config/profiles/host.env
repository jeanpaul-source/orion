# ORION profile: host-only compute
# Source this via scripts/orion.sh or export manually before running commands.
# All heavy compute (embeddings, vector DB, LLM) runs on the host.

# Core services
export ORION_QDRANT_URL="http://192.168.5.10:6333"
export ORION_QDRANT_COLLECTION="orion_homelab"

# Embeddings served by host FastAPI (optional; if unset, local SentenceTransformer will be used)
export ORION_EMBED_URL="http://192.168.5.10:8001"

# vLLM (OpenAI-compatible) endpoint and default model
export ORION_VLLM_URL="http://192.168.5.10:8000/v1"
export ORION_VLLM_MODEL="Qwen/Qwen2.5-Coder-7B-Instruct"

# Optional: port for /ask service
export ORION_ASK_PORT=8010

# Safety: ensure we don't attempt local CUDA on laptop by mistake
export ORION_FORCE_CPU=0

# Optional paths and overrides (leave unset to use defaults from orion_common.paths)
# export ORION_DATA_DIR=""
# export ORION_CONFIG_DIR=""
# export ORION_LOG_LEVEL="INFO"
