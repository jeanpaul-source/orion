# Laptop Profile Environment Variables
# Copy to laptop.env (gitignored) and customize for your laptop

# Laptop IP
ORION_LAPTOP_IP=192.168.5.25

# Host Machine IP (where services run)
ORION_HOST_IP=192.168.5.10

# Service URLs (all on remote host)
QDRANT_URL=http://192.168.5.10:6333
ANYTHINGLLM_URL=http://192.168.5.10:3001
EMBED_SERVER_URL=http://192.168.5.10:8001
OLLAMA_URL=http://192.168.5.10:11434
VLLM_URL=http://192.168.5.10:8000
N8N_URL=http://192.168.5.10:5678

# Profile
ORION_PROFILE=laptop

# Compute (force CPU on laptop to avoid accidental GPU usage)
FORCE_CPU=true

# Logging
LOG_LEVEL=INFO
