# Host Profile Environment Variables
# Copy to host.env (gitignored) and customize for your host machine

# Host Machine IP
ORION_HOST_IP=192.168.5.10

# Service URLs (all on host)
QDRANT_URL=http://192.168.5.10:6333
ANYTHINGLLM_URL=http://192.168.5.10:3001
EMBED_SERVER_URL=http://192.168.5.10:8001
OLLAMA_URL=http://192.168.5.10:11434
VLLM_URL=http://192.168.5.10:8000
N8N_URL=http://192.168.5.10:5678

# Profile
ORION_PROFILE=host

# Compute
FORCE_CPU=false

# Logging
LOG_LEVEL=INFO
