#!/bin/bash
# Auto-activation for users without direnv
# Add to ~/.bashrc or ~/.zshrc:
#   export ORION_AUTO_ACTIVATE=1
#   source /home/jp/orion/orion-harvester/.autorc

if [ "$ORION_AUTO_ACTIVATE" = "1" ]; then
    ORION_ROOT="/home/jp/orion/orion-harvester"

    # Only activate if we're in the orion directory
    if [[ "$PWD" == "$ORION_ROOT"* ]]; then
        EXPECTED_VENV="$ORION_ROOT/.venv"

        # Deactivate wrong venv
        if [ -n "$VIRTUAL_ENV" ] && [ "$VIRTUAL_ENV" != "$EXPECTED_VENV" ]; then
            deactivate 2>/dev/null || true
        fi

        # Activate correct venv
        if [ -z "$VIRTUAL_ENV" ] || [ "$VIRTUAL_ENV" != "$EXPECTED_VENV" ]; then
            if [ -f "$EXPECTED_VENV/bin/activate" ]; then
                source "$EXPECTED_VENV/bin/activate"
            fi
        fi
    fi
fi
