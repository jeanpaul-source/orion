# direnv configuration - auto-activates correct venv when entering directory
# Install direnv: sudo apt install direnv
# Enable in shell: echo 'eval "$(direnv hook bash)"' >> ~/.bashrc
# Allow this file: direnv allow

source_env_if_exists .env

# Deactivate any wrong venv
if [ -n "$VIRTUAL_ENV" ]; then
    # Check if it's the wrong venv
    EXPECTED_VENV="$(pwd)/.venv"
    if [ "$VIRTUAL_ENV" != "$EXPECTED_VENV" ]; then
        echo "⚠️  Deactivating wrong venv: $VIRTUAL_ENV"
        deactivate 2>/dev/null || true
        unset VIRTUAL_ENV
    fi
fi

# Activate correct venv
if [ -d "$(pwd)/.venv" ]; then
    source "$(pwd)/.venv/bin/activate"
    export VIRTUAL_ENV="$(pwd)/.venv"
    PATH_add "$(pwd)/.venv/bin"
    echo "✅ ORION venv auto-activated"
else
    echo "❌ No venv found. Run: python3 -m venv .venv && pip install -e ."
fi

